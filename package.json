{
  "name": "takeshi-castle",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "npm run dev --workspace @takeshi-castle/server",
    "dev:web": "npm run dev --workspace @takeshi-castle/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
